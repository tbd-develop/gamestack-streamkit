{
  "name": "gamestack-streamkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local streaming toolkit for GameStack: Twitch bot + OBS overlays driven by the public API. Runs standalone, separate from the website.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n bot,overlay -c blue,magenta \"npm:dev:bot\" \"npm:dev:overlay\"",
    "dev:bot": "node --watch --env-file-if-exists=.env --import tsx src/index.ts",
    "dev:overlay": "vite",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.2",
    "@twurple/api": "^7.2.0",
    "@twurple/auth": "^7.2.0",
    "@twurple/eventsub-ws": "^7.2.0",
    "fastify": "^5.2.0",
    "pino": "^9.6.0",
    "vue": "^3.5.13",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
