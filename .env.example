# ─────────────────────────────────────────────────────────────────────────────
# GameStack StreamKit configuration. Copy to `.env` and fill in.
# This service is standalone — it only talks to GameStack over HTTP via the key.
# ─────────────────────────────────────────────────────────────────────────────

# GameStack public API (REQUIRED) ────────────────────────────────────────────
GAMESTACK_API_BASE=http://localhost:5259/api/public/v1
# Backend origin — used to turn relative cover-image paths into absolute URLs.
GAMESTACK_BACKEND_ORIGIN=http://localhost:5259
# Mint this in the GameStack app (Settings → API keys). NEVER show it on stream.
GAMESTACK_API_KEY=gs_dev_replace_me

# Server ──────────────────────────────────────────────────────────────────────
STREAMKIT_PORT=8420
COMMAND_PREFIX=!

# Twitch chat (OPTIONAL — leave blank to run API+overlay only) ────────────────
# Chat runs over EventSub (not IRC). All five required together to enable the bot.
# Bot token needs scopes user:read:chat + user:write:chat (+ user:bot if a separate
# bot account). It auto-refreshes, so set the refresh token too. "oauth:" is stripped.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_TOKEN=
TWITCH_BOT_REFRESH=
TWITCH_CHANNEL=

# Twitch EventSub auto "now playing" (Phase 2) ───────────────────────────────
# channel.update needs no scope, but the subscription needs a BROADCASTER user token.
TWITCH_EVENTSUB_ENABLED=false
TWITCH_BROADCASTER_TOKEN=
TWITCH_BROADCASTER_REFRESH=

# YouTube (Phase 3) ───────────────────────────────────────────────────────────
YOUTUBE_ENABLED=false
